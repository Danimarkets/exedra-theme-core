{%- if blocks != blank -%}
  <div class="accordion">
    {%- for block in blocks -%}
      <div class="accordion__item">
        <button type="button" class="accordion__summary" aria-expanded="false" data-accordion-toggle>
          <span>{{ block.settings.heading }}</span>
          <span>+</span>
        </button>
        <div class="accordion__content" hidden>
          {{ block.settings.content }}
        </div>
      </div>
    {%- endfor -%}
  </div>
{%- endif -%}
