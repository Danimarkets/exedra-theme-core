{%- assign item = product -%}
<article class="product-card card">
  <a href="{{ item.url | default: '#' }}" class="product-card__media">
    {%- if item != blank and item.featured_image != blank -%}
      {{ item.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300, 500, 800', alt: item.title | escape }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </a>
  <div class="product-card__content">
    <h3 class="product-card__title"><a href="{{ item.url | default: '#' }}">{{ item.title | default: fallback_title }}</a></h3>
    <div class="product-card__meta">
      <span class="product-card__price">{%- if item != blank -%}{{ item.price | money }}{%- else -%}$0{%- endif -%}</span>
      <a href="{{ item.url | default: '#' }}">Ver</a>
    </div>
  </div>
</article>
