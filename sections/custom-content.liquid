<section {% render 'motion-attrs', section: section, class_name: 'section custom-content-section' %}>
  <div class="page-width">
    <div class="card motion-item" style="padding: 1.5rem;">
      {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}
      <div class="collections-editorial-grid">
        {%- for block in section.blocks -%}
          <div class="card motion-item" style="padding: 1rem; box-shadow: none; border: 1px solid rgba(2,22,47,.08);">
            {%- if block.settings.title != blank -%}<h3 style="margin-top:0;">{{ block.settings.title }}</h3>{%- endif -%}
            {%- if block.settings.text != blank -%}<div class="rte">{{ block.settings.text }}</div>{%- endif -%}
            {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
              <div style="margin-top: 1rem;">
                {% render 'button', label: block.settings.button_label, url: block.settings.button_link, style: 'ghost' %}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom content",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Custom content system"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Sección flexible para armar layouts híbridos sin tocar código.</p>"},
    {% render 'motion-settings' %}
  ],
  "blocks": [
    {"type":"content","name":"Content block","settings":[
      {"type":"text","id":"title","label":"Title","default":"Bloque flexible"},
      {"type":"richtext","id":"text","label":"Text","default":"<p>Contenido reusable por cliente, campaña o producto.</p>"},
      {"type":"text","id":"button_label","label":"Button label","default":"Explorar"},
      {"type":"url","id":"button_link","label":"Button link"}
    ]}
  ],
  "max_blocks": 8,
  "presets": [{"name":"Custom content","blocks":[{"type":"content"},{"type":"content"},{"type":"content"}]}]
}
{% endschema %}
