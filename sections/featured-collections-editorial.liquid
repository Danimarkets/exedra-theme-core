<section {% render 'motion-attrs', section: section, class_name: 'section featured-collections-editorial' %}>
  <div class="page-width">
    {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}
    <div class="collections-editorial-grid">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        <div class="motion-item">
          {% render 'editorial-card',
            title: collection.title | default: block.settings.fallback_title,
            text: block.settings.text | default: collection.description | strip_html | truncatewords: 20,
            url: collection.url | default: block.settings.link
          %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collections editorial",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Colecciones destacadas"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Bloque editorial para dirigir navegación y storytelling hacia colecciones clave.</p>"},
    {% render 'motion-settings' %}
  ],
  "blocks": [
    {"type":"collection_tile","name":"Collection tile","settings":[
      {"type":"collection","id":"collection","label":"Collection"},
      {"type":"text","id":"fallback_title","label":"Fallback title","default":"Colección destacada"},
      {"type":"text","id":"text","label":"Text","default":"Texto corto para dirigir la intención comercial."},
      {"type":"url","id":"link","label":"Button link"}
    ]}
  ],
  "max_blocks": 6,
  "presets": [{"name":"Featured collections editorial","blocks":[{"type":"collection_tile"},{"type":"collection_tile"},{"type":"collection_tile"}]}]
}
{% endschema %}
