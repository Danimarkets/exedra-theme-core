<section class="section featured-collection">
  <div class="page-width">
    {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}

    <div class="featured-grid">
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <article class="product-card card">
            <a href="{{ product.url }}" class="product-card__media">
              {%- if product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300, 500, 800', alt: product.title | escape }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
            <div class="product-card__content">
              <h3 class="product-card__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              <div class="product-card__meta">
                <span class="product-card__price">{{ product.price | money }}</span>
                <a href="{{ product.url }}">Ver</a>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <article class="product-card card">
            <div class="product-card__media">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="product-card__content">
              <h3 class="product-card__title">Producto destacado {{ i }}</h3>
              <div class="product-card__meta">
                <span class="product-card__price">$0</span>
                <span>Demo</span>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Productos destacados"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Bloque base para destacar colección o merchandising de temporada.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
