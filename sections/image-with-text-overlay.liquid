<section {% render 'motion-attrs', section: section, class_name: 'section image-with-text-overlay-section' %}>
  <div class="page-width">
    <div class="image-overlay-card motion-item">
      <div class="image-overlay-card__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '600, 1000, 1600', alt: section.settings.heading | escape }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="image-overlay-card__content">
        {%- if section.settings.eyebrow != blank -%}<div class="hero__eyebrow">{{ section.settings.eyebrow }}</div>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="hero__title" style="max-width: 10ch;">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="hero__text rte">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          <div style="margin-top: 1.25rem;">{% render 'button', label: section.settings.button_label, url: section.settings.button_link, style: 'secondary' %}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text overlay",
  "settings": [
    {"type":"image_picker","id":"image","label":"Image"},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Editorial block"},
    {"type":"text","id":"heading","label":"Heading","default":"Bloque overlay premium"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Úsalo para campañas, manifiestos de marca o lanzamientos con peso visual fuerte.</p>"},
    {"type":"text","id":"button_label","label":"Button label","default":"Explorar"},
    {"type":"url","id":"button_link","label":"Button link"},
    {% render 'motion-settings' %}
  ],
  "presets": [{"name":"Image with text overlay"}]
}
{% endschema %}
