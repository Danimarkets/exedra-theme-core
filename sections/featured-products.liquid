<section class="section featured-products">
  <div class="page-width">
    {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}

    <div class="products-grid">
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        <article class="product-card card">
          <a href="{{ product.url | default: '#' }}" class="product-card__media">
            {%- if product != blank and product.featured_image != blank -%}
              {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300, 500, 800', alt: product.title | escape }}
            {%- else -%}
              {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </a>
          <div class="product-card__content">
            <h3 class="product-card__title">
              <a href="{{ product.url | default: '#' }}">{{ product.title | default: block.settings.fallback_title }}</a>
            </h3>
            <div class="product-card__meta">
              <span class="product-card__price">{%- if product != blank -%}{{ product.price | money }}{%- else -%}$0{%- endif -%}</span>
              <a href="{{ product.url | default: '#' }}">Ver</a>
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Selección curada"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Este bloque permite combinar productos manualmente para campañas, lanzamientos o storytelling comercial.</p>"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "fallback_title",
          "label": "Fallback title",
          "default": "Producto curado"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Featured products",
      "blocks": [
        {"type": "product"},
        {"type": "product"},
        {"type": "product"},
        {"type": "product"}
      ]
    }
  ]
}
{% endschema %}
