<section {% render 'motion-attrs', section: section, class_name: 'section featured-products' %}>
  <div class="page-width">
    {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}
    <div class="products-grid">
      {%- for block in section.blocks -%}
        <div class="motion-item">{% render 'product-card', product: block.settings.product, fallback_title: block.settings.fallback_title %}</div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Selección curada"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Este bloque permite combinar productos manualmente para campañas, lanzamientos o storytelling comercial.</p>"},
    {% render 'motion-settings' %}
  ],
  "blocks": [{"type":"product","name":"Product","settings":[{"type":"product","id":"product","label":"Product"},{"type":"text","id":"fallback_title","label":"Fallback title","default":"Producto curado"}]}],
  "max_blocks": 4,
  "presets": [{"name":"Featured products","blocks":[{"type":"product"},{"type":"product"},{"type":"product"},{"type":"product"}]}]
}
{% endschema %}
