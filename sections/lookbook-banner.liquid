<section {% render 'motion-attrs', section: section, class_name: 'section lookbook-banner-section' %}>
  <div class="page-width">
    <div class="image-overlay-card motion-item">
      {% render 'media-frame', image: section.settings.image, wrapper_class: 'image-overlay-card__media', image_width: 1800, widths: '600, 1200, 1800', alt: section.settings.heading, placeholder: 'image' %}
      {% render 'overlay-content',
        heading: section.settings.heading,
        text: section.settings.text,
        primary_label: section.settings.button_label,
        primary_url: section.settings.button_link,
        primary_style: 'secondary'
      %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lookbook banner",
  "settings": [
    {"type":"image_picker","id":"image","label":"Image"},
    {"type":"text","id":"heading","label":"Heading","default":"Lookbook principal"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Sección para cápsulas, editoriales o campañas con aspiracionalidad visual.</p>"},
    {"type":"text","id":"button_label","label":"Button label","default":"Explorar lookbook"},
    {"type":"url","id":"button_link","label":"Button link"},
    {% render 'motion-settings' %}
  ],
  "presets": [{"name":"Lookbook banner"}]
}
{% endschema %}
