<section {% render 'motion-attrs', section: section, class_name: 'section multicolumn-section' %}>
  <div class="page-width">
    {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}
    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        <article class="card motion-item" style="padding: 1.25rem;">
          {%- if block.settings.title != blank -%}<h3 style="margin-top:0;">{{ block.settings.title }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<div class="rte">{{ block.settings.text }}</div>{%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Multicolumn",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Multicolumn content"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Ideal para beneficios, procesos, argumentos de venta o pilares de marca.</p>"},
    {% render 'motion-settings' %}
  ],
  "blocks": [
    {"type":"column","name":"Column","settings":[
      {"type":"text","id":"title","label":"Title","default":"Columna"},
      {"type":"richtext","id":"text","label":"Text","default":"<p>Contenido flexible para estructurar información con claridad.</p>"}
    ]}
  ],
  "max_blocks": 6,
  "presets": [{"name":"Multicolumn","blocks":[{"type":"column"},{"type":"column"},{"type":"column"}]}]
}
{% endschema %}
