<section {% render 'motion-attrs', section: section, class_name: 'section featured-product-section' %}>
  <div class="page-width">
    {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}
    {%- assign featured_product = section.settings.product -%}
    <div class="product-main__grid" style="margin-top: 1.5rem;">
      <div class="product-main__media card motion-item">
        <div class="product-main__gallery-main">
          {%- if featured_product != blank and featured_product.featured_image != blank -%}
            {{ featured_product.featured_image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '600, 900, 1400', alt: featured_product.title | escape }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
      <div class="product-main__buybox card motion-item">
        <h2 class="product-main__title">{{ featured_product.title | default: 'Producto destacado' }}</h2>
        {%- if featured_product != blank -%}<div class="product-main__price">{{ featured_product.price | money }}</div>{%- endif -%}
        {%- if section.settings.custom_text != blank -%}
          <div class="product-main__description rte">{{ section.settings.custom_text }}</div>
        {%- elsif featured_product.description != blank -%}
          <div class="product-main__description rte">{{ featured_product.description | strip_html | truncatewords: 40 }}</div>
        {%- endif -%}
        <div class="product-main__actions">
          <a href="{{ featured_product.url | default: '#' }}" class="button">Ver producto</a>
          {%- if section.settings.secondary_link != blank and section.settings.secondary_label != blank -%}
            <a href="{{ section.settings.secondary_link }}" class="button button--ghost">{{ section.settings.secondary_label }}</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured product",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Producto destacado"},
    {"type":"richtext","id":"text","label":"Intro text","default":"<p>Bloque para impulsar una referencia clave, lanzamiento o best seller.</p>"},
    {"type":"product","id":"product","label":"Product"},
    {"type":"richtext","id":"custom_text","label":"Custom text"},
    {"type":"text","id":"secondary_label","label":"Secondary button label","default":"Explorar más"},
    {"type":"url","id":"secondary_link","label":"Secondary button link"},
    {% render 'motion-settings' %}
  ],
  "presets": [{"name":"Featured product"}]
}
{% endschema %}
