<section {% render 'motion-attrs', section: section, class_name: 'section collection-showcase-section' %}>
  <div class="page-width">
    {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}
    <div class="collections-editorial-grid">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        <div class="motion-item">
          {% render 'editorial-card',
            title: collection.title | default: block.settings.title,
            text: block.settings.text,
            url: collection.url | default: block.settings.link
          %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection showcase",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Collection showcase"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Sección para agrupar colecciones, categorías o líneas comerciales.</p>"},
    {% render 'motion-settings' %}
  ],
  "blocks": [
    {"type":"collection","name":"Collection card","settings":[
      {"type":"collection","id":"collection","label":"Collection"},
      {"type":"text","id":"title","label":"Title","default":"Colección"},
      {"type":"text","id":"text","label":"Text","default":"Texto corto de apoyo comercial."},
      {"type":"url","id":"link","label":"Button link"}
    ]}
  ],
  "max_blocks": 6,
  "presets": [{"name":"Collection showcase","blocks":[{"type":"collection"},{"type":"collection"},{"type":"collection"}]}]
}
{% endschema %}
