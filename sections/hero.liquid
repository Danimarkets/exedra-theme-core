<section {% render 'motion-attrs', section: section, class_name: 'hero' %}>
  <div class="page-width hero__inner">
    {%- if section.settings.eyebrow != blank -%}
      <div class="hero__eyebrow motion-item">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h1 class="hero__title motion-item">{{ section.settings.title }}</h1>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="hero__text rte motion-item">{{ section.settings.text }}</div>
    {%- endif -%}
    <div class="motion-item">
      {% render 'button-group',
        primary_label: section.settings.primary_button_label,
        primary_url: section.settings.primary_button_link,
        primary_style: 'primary',
        secondary_label: section.settings.secondary_button_label,
        secondary_url: section.settings.secondary_button_link,
        secondary_style: 'secondary'
      %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Exedra Theme Core"},
    {"type":"textarea","id":"title","label":"Title","default":"Theme base modular para escalar ecommerce"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Construido para marcas de beauty, moda y ecommerce visual que necesitan una base flexible y seria.</p>"},
    {"type":"text","id":"primary_button_label","label":"Primary button label","default":"Explorar"},
    {"type":"url","id":"primary_button_link","label":"Primary button link"},
    {"type":"text","id":"secondary_button_label","label":"Secondary button label","default":"Ver estructura"},
    {"type":"url","id":"secondary_button_link","label":"Secondary button link"},
    {"type":"header","content":"Motion"},
    {"type":"checkbox","id":"enable_motion","label":"Enable motion","default":false},
    {"type":"select","id":"motion_preset","label":"Motion preset","default":"fade-up","options":[{"value":"fade-up","label":"Fade up"},{"value":"fade-left","label":"Fade left"},{"value":"fade-right","label":"Fade right"},{"value":"scale-in","label":"Scale in"}]},
    {"type":"select","id":"motion_intensity","label":"Motion intensity","default":"medium","options":[{"value":"subtle","label":"Subtle"},{"value":"medium","label":"Medium"},{"value":"bold","label":"Bold"}]},
    {"type":"checkbox","id":"motion_stagger","label":"Stagger cards","default":false},
    {"type":"select","id":"motion_trigger","label":"Motion trigger","default":"viewport","options":[{"value":"viewport","label":"On viewport"},{"value":"immediate","label":"Immediate"}]}
  ],
  "presets": [{"name":"Hero"}]
}
{% endschema %}
