<section {% render 'motion-attrs', section: section, class_name: 'section image-with-text' %}>
  <div class="page-width image-with-text__grid">
    <div class="image-with-text__media card motion-item">
      {% render 'media-frame', image: section.settings.image, wrapper_class: '', image_width: 1200, widths: '400, 800, 1200', alt: section.settings.heading, placeholder: 'image' %}
    </div>
    <div class="image-with-text__content motion-item">
      {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}
      <div style="margin-top: 1.5rem;">
        {% render 'button-group', primary_label: section.settings.button_label, primary_url: section.settings.button_link, primary_style: 'ghost' %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    {"type":"image_picker","id":"image","label":"Image"},
    {"type":"text","id":"heading","label":"Heading","default":"Bloque editorial reusable"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Este módulo sirve para contar historia de marca, explicar propuestas de valor o construir contexto comercial.</p>"},
    {"type":"text","id":"button_label","label":"Button label","default":"Conocer más"},
    {"type":"url","id":"button_link","label":"Button link"},
    {% render 'motion-settings' %}
  ],
  "presets": [{"name":"Image with text"}]
}
{% endschema %}
