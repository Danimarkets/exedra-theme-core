<section {% render 'motion-attrs', section: section, class_name: 'section lookbook-slider-section' %}>
  <div class="page-width">
    {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}
    <div class="featured-grid">
      {%- for block in section.blocks -%}
        <article class="card motion-item image-gallery__item">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '400, 800, 1200', alt: block.settings.title | escape }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <div class="image-gallery__caption">
            <strong>{{ block.settings.title }}</strong>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lookbook slider",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Lookbook slider"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Shell base para una futura versión con navegación deslizante más compleja.</p>"},
    {% render 'motion-settings' %}
  ],
  "blocks": [
    {"type":"slide","name":"Slide","settings":[
      {"type":"image_picker","id":"image","label":"Image"},
      {"type":"text","id":"title","label":"Title","default":"Slide visual"}
    ]}
  ],
  "max_blocks": 8,
  "presets": [{"name":"Lookbook slider","blocks":[{"type":"slide"},{"type":"slide"},{"type":"slide"}]}]
}
{% endschema %}
