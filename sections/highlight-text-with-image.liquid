<section {% render 'motion-attrs', section: section, class_name: 'section highlight-text-with-image' %}>
  <div class="page-width highlight-grid">
    <div class="highlight-grid__content motion-item">
      {%- if section.settings.heading != blank -%}<h2 class="section-heading__title" style="font-size: clamp(2rem, 4vw, 4rem);">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<div class="section-heading__text rte">{{ section.settings.text }}</div>{%- endif -%}
      {%- if section.settings.highlight != blank -%}<div class="highlight-grid__callout">{{ section.settings.highlight }}</div>{%- endif -%}
    </div>
    <div class="highlight-grid__media card motion-item">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '400, 800, 1200', alt: section.settings.heading | escape }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Highlight text with image",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Texto protagonista con soporte visual"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Sección pensada para mensajes contundentes, claims, narrativa premium y campañas destacadas.</p>"},
    {"type":"text","id":"highlight","label":"Highlight line","default":"Un claim fuerte, una promesa clara o una idea principal."},
    {"type":"image_picker","id":"image","label":"Image"},
    {% render 'motion-settings' %}
  ],
  "presets": [{"name":"Highlight text with image"}]
}
{% endschema %}
