<section {% render 'motion-attrs', section: section, class_name: 'section slideshow-section' %}>
  <div class="page-width">
    <div class="slideshow card motion-item">
      {%- for block in section.blocks -%}
        <article class="slideshow__slide">
          {% render 'media-frame', image: block.settings.image, wrapper_class: 'slideshow__media', image_width: 1800, widths: '600, 1200, 1800', alt: block.settings.heading, placeholder: 'image' %}
          {% render 'overlay-content',
            class_name: 'slideshow__content',
            eyebrow: block.settings.eyebrow,
            heading: block.settings.heading,
            text: block.settings.text,
            primary_label: block.settings.button_label,
            primary_url: block.settings.button_link,
            primary_style: 'secondary'
          %}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {% render 'motion-settings' %}
  ],
  "blocks": [
    {"type":"slide","name":"Slide","settings":[
      {"type":"image_picker","id":"image","label":"Image"},
      {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Campaña"},
      {"type":"text","id":"heading","label":"Heading","default":"Slide principal"},
      {"type":"richtext","id":"text","label":"Text","default":"<p>Bloque base para campañas, temporadas o mensajes hero rotativos.</p>"},
      {"type":"text","id":"button_label","label":"Button label","default":"Explorar"},
      {"type":"url","id":"button_link","label":"Button link"}
    ]}
  ],
  "max_blocks": 5,
  "presets": [{"name":"Slideshow","blocks":[{"type":"slide"},{"type":"slide"}]}]
}
{% endschema %}
