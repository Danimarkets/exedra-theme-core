<section {% render 'motion-attrs', section: section, class_name: 'section slideshow-section' %}>
  <div class="page-width">
    <div class="slideshow card motion-item">
      {%- for block in section.blocks -%}
        <article class="slideshow__slide">
          <div class="slideshow__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', widths: '600, 1200, 1800', alt: block.settings.heading | escape }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="slideshow__content">
            {%- if block.settings.eyebrow != blank -%}<div class="hero__eyebrow">{{ block.settings.eyebrow }}</div>{%- endif -%}
            {%- if block.settings.heading != blank -%}<h2 class="hero__title" style="max-width: 10ch;">{{ block.settings.heading }}</h2>{%- endif -%}
            {%- if block.settings.text != blank -%}<div class="hero__text rte">{{ block.settings.text }}</div>{%- endif -%}
            {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
              <div style="margin-top:1rem;">{% render 'button', label: block.settings.button_label, url: block.settings.button_link, style: 'secondary' %}</div>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Slideshow",
  "settings": [
    {% render 'motion-settings' %}
  ],
  "blocks": [
    {"type":"slide","name":"Slide","settings":[
      {"type":"image_picker","id":"image","label":"Image"},
      {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Campaña"},
      {"type":"text","id":"heading","label":"Heading","default":"Slide principal"},
      {"type":"richtext","id":"text","label":"Text","default":"<p>Bloque base para campañas, temporadas o mensajes hero rotativos.</p>"},
      {"type":"text","id":"button_label","label":"Button label","default":"Explorar"},
      {"type":"url","id":"button_link","label":"Button link"}
    ]}
  ],
  "max_blocks": 5,
  "presets": [{"name":"Slideshow","blocks":[{"type":"slide"},{"type":"slide"}]}]
}
{% endschema %}
