<section {% render 'motion-attrs', section: section, class_name: 'section faq' %}>
  <div class="page-width motion-item">
    {% render 'section-heading', title: section.settings.heading, text: section.settings.text %}
    {% render 'accordion', blocks: section.blocks %}
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Preguntas frecuentes"},
    {"type":"richtext","id":"text","label":"Text","default":"<p>Bloque listo para reducir fricción, resolver dudas y apoyar la conversión.</p>"},
    {% render 'motion-settings' %}
  ],
  "blocks": [
    {"type":"question","name":"Question","settings":[
      {"type":"text","id":"heading","label":"Question","default":"¿Cómo funciona este bloque?"},
      {"type":"richtext","id":"content","label":"Answer","default":"<p>Sirve para resolver preguntas clave antes de que el usuario abandone la compra.</p>"}
    ]}
  ],
  "max_blocks": 8,
  "presets": [{"name":"FAQ","blocks":[{"type":"question"},{"type":"question"},{"type":"question"}]}]
}
{% endschema %}
